# SlipVision Environment Configuration
# Copy this file to .env and fill in your actual values

# ===== DATABASE =====
# PostgreSQL database URL (e.g., Neon, Supabase)
# Local: postgresql://user:password@localhost:5432/slipvision_db?schema=public
# Cloud: postgresql://neondb_owner:password@ep-xxx.region.aws.neon.tech/neondb
DATABASE_URL="postgresql://user:password@host/database"

# ===== OCR AI (Typhoon) =====
# Thai bank slip OCR and text extraction
# Get from: https://cloud.typhoon.ai
TYPHOON_API_KEY="sk-xxxxx"
TYPHOON_BASE_URL="https://api.opentyphoon.ai/v1"

# ===== NEXTAUTH =====
# JWT secret for session signing
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-random-secret-here"

# Application URL (used for OAuth callbacks and session validation)
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# ===== VERCEL BLOB STORAGE =====
# Image upload storage (for bank slip images)
# Get from: https://vercel.com/storage/blob
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxx"
